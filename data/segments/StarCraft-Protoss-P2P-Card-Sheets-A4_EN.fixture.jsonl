{"id": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN:p0:ability:0", "doc": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN", "page": 0, "kind": "body", "source_text": "Place a Shadow token completely within 12\" of any model in this Unit. At the end of the round, the controlling player may place all models in this Unit in coherency, treating the Shadow token as the leader model. The Shadow token has DISPLACEMENT.", "target_text": "Umieść żeton Cienia całkowicie w promieniu 12\" od dowolnego modelu tej jednostki. Na końcu rundy gracz kontrolujący może ustawić wszystkie modele tej jednostki w spójności, traktując żeton Cienia jako model prowadzący. Żeton Cienia ma PRZEMIESZCZENIE.", "bold": [[13, 19], [20, 46], [82, 96], [162, 171], [189, 195], [201, 217], [225, 231], [235, 250]], "status": "fixture", "notes": "ability 'PSIONIC TRANSFER'; bold ranges pre-computed from KEYWORDS auto-bold"}
{"id": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN:p0:ability:1", "doc": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN", "page": 0, "kind": "body", "source_text": "All allied Units' weapons attacking an enemy Unit within 4\" of the Shadow token gain PRECISION (1).", "target_text": "Wszystkie bronie sojuszniczych jednostek atakujące wrogą jednostkę w promieniu 4\" od żetonu Cienia zyskują PRECYZJĘ (1).", "bold": [[10, 16], [17, 30], [51, 56], [67, 81], [92, 98], [107, 119]], "status": "fixture", "notes": "ability 'PSIONIC PRESENCE'; bold ranges pre-computed from KEYWORDS auto-bold"}
{"id": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN:p0:ability:2", "doc": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN", "page": 0, "kind": "body", "source_text": "This Unit's Glaive Cannon gains BUFF RoA (1).", "target_text": "Działo glewii tej jednostki zyskuje WZMOCNIENIE RoA (1).", "bold": [[0, 13], [36, 55]], "status": "fixture", "notes": "ability 'RESONATING GLAVES'; bold ranges pre-computed from KEYWORDS auto-bold"}
{"id": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN:p0:ability:3", "doc": "StarCraft-Protoss-P2P-Card-Sheets-A4_EN", "page": 0, "kind": "body", "source_text": "This Unit's ranged Glaive Cannon weapon gains ANTI-EVADE (2).", "target_text": "Broń dystansowa Działa glewii tej jednostki zyskuje ANTY-UNIK (2).", "bold": [[16, 29], [52, 65]], "status": "fixture", "notes": "ability 'GUIDANCE'; bold ranges pre-computed from KEYWORDS auto-bold"}
